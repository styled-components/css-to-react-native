{
  "name": "css-to-react-native",
  "version": "4.0.0",
  "description": "Convert CSS text to a React Native stylesheet object",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "rollup ./src/index.js -o index.js --f cjs && babel index.js -o index.js",
    "format": "biome format",
    "lint": "biome lint",
    "precommit": "lint-staged",
    "prepublish": "npm run build",
    "test": "pnpm lint && pnpm format && pnpm unit",
    "unit": "vitest",
    "unit:watch": "vitest --watch"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/styled-components/css-to-react-native.git"
  },
  "keywords": [
    "styled-components",
    "React",
    "ReactNative",
    "styles",
    "CSS"
  ],
  "author": "Jacob Parker",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/styled-components/css-to-react-native/issues"
  },
  "homepage": "https://github.com/styled-components/css-to-react-native#readme",
  "devDependencies": {
    "@babel/cli": "^7.6.2",
    "@babel/core": "^7.1.0",
    "@babel/preset-env": "^7.6.2",
    "@biomejs/biome": "2.4.9",
    "lint-staged": "^6.1.0",
    "rollup": "^1.22.0",
    "vitest": "^4.0.1"
  },
  "dependencies": {
    "camelize": "^1.0.0",
    "css-color-keywords": "^1.0.0",
    "postcss-value-parser": "^4.0.2"
  },
  "lint-staged": {
    "*.js": [
      "biome check",
      "git add"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
